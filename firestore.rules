rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      // Must be authenticated
      return request.auth != null && (
        // Option 1: Hardcoded admin email (initial admin)
        (request.auth.token.email == "arafatinbusiness@gmail.com" && 
         request.auth.token.email_verified == true) ||
        // Option 2: Has user document with role == 'admin'
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Users collection
    match /users/{userId} {
      // Everyone can read users
      allow read: if true;
      // Only admins can write
      allow write: if isAdmin();
    }

    // Fundings collection  
    match /fundings/{fundingId} {
      // Everyone can read
      allow read: if true;
      // Only admins can write
      allow write: if isAdmin();
    }

    // Logs collection
    match /logs/{logId} {
      // Everyone can read
      allow read: if true;
      // Only admins can create
      allow create: if isAdmin();
      // Only admins can delete (for fixing mistakes)
      allow delete: if isAdmin();
      // No one can update
      allow update: if false;
    }

    // Fund info collection
    match /fund_info/{infoId} {
      // Everyone can read
      allow read: if true;
      // Only admins can write
      allow write: if isAdmin();
    }
  }
}